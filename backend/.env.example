# Copy to .env and fill in values as needed
JWT_SECRET=change-me-to-a-random-string

# LLM provider: "openai" (preferred) or "gemini" (optional)
LLM_PROVIDER=openai

# --- OpenAI (ChatGPT) — primary ---
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_FALLBACK_MODELS=gpt-4o-mini,gpt-3.5-turbo
OPENAI_MAX_RETRIES=3

# --- Google Gemini (optional fallback) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro
GEMINI_FALLBACK_MODELS=gemini-2.5-flash,gemini-2.0-flash
GEMINI_MAX_RETRIES=3

RAG_TOP_K=3
MAX_OUTPUT_TOKENS=8192
TEMPERATURE=0.25

# --- Storage backend ---
# "local"     = JSON files on disk (default, no setup required)
# "firestore" = Google Firestore via firebase-admin (production-ready, multi-user)
STORAGE_BACKEND=local

# Required only when STORAGE_BACKEND=firestore. Pick ONE of the two
# credential mechanisms below (env-var JSON wins if both are set).
#
# Option A — RECOMMENDED for cloud (Render, Heroku, Cloud Run, Fly.io):
#   Paste the entire service-account JSON as a single env var.
#   Easiest because no file mount is needed.
# FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","..."}
FIREBASE_CREDENTIALS_JSON=
#
# Option B — RECOMMENDED for local dev / Docker bind-mounts:
#   Filesystem path to the downloaded service-account JSON file.
# FIREBASE_CREDENTIALS_PATH=C:\path\to\firebase-adminsdk.json
FIREBASE_CREDENTIALS_PATH=
#
# Always required when STORAGE_BACKEND=firestore (matches "project_id" in the JSON).
FIREBASE_PROJECT_ID=
