JWT_SECRET=change-me-to-a-random-string

# Default LLM provider on boot. Only TWO providers are supported by
# this deployment — pick whichever should be the boot-time default.
# (Users can flip between any *registered* provider in the Sidebar
# at runtime; admins can pin a per-agent override per user from the
# Admin > Model Overrides tab.)
# Valid values: gemini | cursor
LLM_PROVIDER=gemini

# --- Google Gemini (native API; required for RAG embeddings) --------------
# Used for both LLM calls and RAG embeddings (text-embedding-004). Even
# if you primarily route traffic through Cursor CLI, GEMINI_API_KEY
# must remain set so the vector store can build embeddings.
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-pro
GEMINI_FALLBACK_MODELS=gemini-2.5-flash,gemini-2.0-flash
GEMINI_MAX_RETRIES=3
GEMINI_EMBED_MODEL=models/text-embedding-004

# --- Cursor CLI (cursor-agent) — second LLM provider ----------------------
# Shells out to the locally-installed cursor-agent binary. NOTE: Cursor
# seats are licensed per developer for IDE use; routing end-user traffic
# through this provider is a gray-area violation of the Cursor ToS.
# Treat as a developer-only convenience.
#
# CURSOR_AGENT_BIN — leave blank to AUTO-DISCOVER the binary. The
# backend walks these locations in order and uses the first hit:
#     1. PATH                                   (cursor-agent / agent)
#     2. %LOCALAPPDATA%\cursor-agent\           (Windows installer)
#     3. %LOCALAPPDATA%\Programs\cursor\        (Windows IDE bundle)
#     4. ~/.local/bin/cursor-agent              (macOS / Linux)
# Only set this explicitly when the binary lives somewhere non-standard.
# An invalid explicit path triggers auto-discovery with a warning, so a
# stale entry never strands the provider.
CURSOR_AGENT_BIN=
# Comma-separated catalog of every model the Sidebar dropdown should
# offer for the Cursor provider. Acts as a floor when the live
# `cursor-agent --list-models` probe fails (e.g. user not yet logged
# in via `cursor-agent login`). Once logged in, CURSOR_AGENT_DISCOVER
# merges the seat's actual entitlements with this static list.
CURSOR_AGENT_MODELS=auto,composer-1,sonic,gpt-5,gpt-5-codex,gpt-5-fast,gpt-5-mini,gpt-4.1,gpt-4o,o3,o3-mini,o4-mini,sonnet-4,sonnet-4-thinking,opus-4,haiku-4,claude-sonnet-4.5,claude-opus-4.1,claude-haiku-4.5,claude-3.7-sonnet,claude-3.5-sonnet,gemini-2.5-pro,gemini-2.5-flash,grok-4,grok-code-fast-1
CURSOR_AGENT_MAX_RETRIES=2
CURSOR_AGENT_DISCOVER=true

RAG_TOP_K=3
MAX_OUTPUT_TOKENS=8192
# Default 0.0 = greedy decoding so identical INPUT produces identical
# OUTPUT (the user-visible "same input = same output" guarantee).
# Bump to 0.2-0.4 if you want a little creativity.
TEMPERATURE=0.0
# Fixed seed forwarded to Gemini's GenerateContentConfig for the small
# slice of randomness that survives temperature=0. Change this number
# (or temporarily set TEMPERATURE>0) to deliberately re-roll a prompt.
LLM_SEED=7
# Memoize LLM outputs by hash of (agent, qa_mode, project, input,
# effective_system_prompt). On a cache hit the stored output is
# replayed verbatim — no second LLM call, no RAG retrieval, no
# variance from the model side. Disable to always hit the LLM.
LLM_RESPONSE_CACHE_ENABLED=true
# Soft cap on cached entries; oldest are evicted FIFO once exceeded.
LLM_RESPONSE_CACHE_MAX_ENTRIES=1000

# --- Storage backend: "local" (default JSON files) or "firestore" ---
# Set to "firestore" to enable Google Firestore (multi-user, production-ready).
STORAGE_BACKEND=Firestore

# Required only when STORAGE_BACKEND=firestore. Pick ONE of the two
# credential mechanisms below (env-var JSON wins if both are set).
#
# Option A — RECOMMENDED for cloud (Render, Heroku, Cloud Run, Fly.io):
#   Paste the entire service-account JSON as a single env var.
#   Easiest because no file mount is needed.
# FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","..."}
# FIREBASE_CREDENTIALS_JSON={
#   "type": "service_account",
#   "project_id": "your-project-id",
#   "private_key_id": "...",
#   "private_key": "-----BEGIN PRIVATE KEY-----\n...your private key...\n-----END PRIVATE KEY-----\n",
#   "client_email": "firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com",
#   "client_id": "...",
#   "auth_uri": "https://accounts.google.com/o/oauth2/auth",
#   "token_uri": "https://oauth2.googleapis.com/token",
#   "auth_provider_x509_cert_url": "https://www.googleapis.com/oauth2/v1/certs",
#   "client_x509_cert_url": "https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk-xxxxx%40your-project-id.iam.gserviceaccount.com",
#   "universe_domain": "googleapis.com"
# }
FIREBASE_CREDENTIALS_JSON=

#
# Option B — RECOMMENDED for local dev / Docker bind-mounts:
#   Filesystem path to the downloaded service-account JSON file.
# FIREBASE_CREDENTIALS_PATH=C:\path\to\firebase-adminsdk.json
FIREBASE_CREDENTIALS_PATH=C:\Users\ro.shah\sf-qa-web\Secrets\qa-studio-agent-firebase-adminsdk-fbsvc-d2ce7019a0.json
#
# Always required when STORAGE_BACKEND=firestore (matches "project_id" in the JSON).
FIREBASE_PROJECT_ID=qa-studio-agent

# Firebase Storage bucket — DEPRECATED. Documents now live in a Google
# Workspace Shared Drive (see GDRIVE_* below). Left here for the
# migration script and the legacy fallback shim only.
FIREBASE_STORAGE_BUCKET=qa-studio-agent.appspot.com

# --- Google Drive (Shared Drive) — primary doc storage ---
# Project documents are stored in a Google Workspace Shared Drive,
# inside <GDRIVE_PARENT_FOLDER_NAME>/<project-folder>/<file>.
#
# Operator setup (one time):
#   1. In Google Workspace admin, create a Shared Drive (or pick one).
#   2. Add the service-account email from FIREBASE_CREDENTIALS_PATH /
#      _JSON to that Shared Drive as Content Manager (or higher).
#   3. Copy the Shared Drive ID into GDRIVE_SHARED_DRIVE_ID below.
# The first upload then auto-creates "QA Studio Agents/<project>/".
GDRIVE_SHARED_DRIVE_ID=
GDRIVE_PARENT_FOLDER_NAME=QA Studio Agents

# --- Google Drive integration (per-user OAuth, separate feature) ---
# Create an OAuth 2.0 Client ID (type "Web application") in Google Cloud Console,
# enable the Google Drive API, and add the redirect URI below to the client config.
GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8080/api/gdrive/callback

# --- MCP (Model Context Protocol) client ---
# When projects have MCP servers configured (per-project, see UI), the
# orchestrator pulls their resources at runtime and appends them as RAG
# context. These knobs cap the per-project budget so a slow / dead MCP
# server can't stall agent runs.
MCP_CACHE_TTL_SEC=120
MCP_REQUEST_TIMEOUT_SEC=10

# --- AES-256-GCM encryption-at-rest ---
# When set, every sensitive field stored in Firestore (or local-JSON
# fallback) is encrypted before write and decrypted on read:
#   * jira_sessions.api_token
#   * gdrive_sessions.access_token / refresh_token / client_secret
#   * xray_sessions.client_secret
#   * zephyr_sessions.api_token
#   * mcp_servers.headers
#   * users.prompt_overrides
#   * agent_runs.input / .output
#
# Generate a new key locally (32 random bytes, base64-encoded):
#   cd backend && python -m scripts.gen_encryption_key
# or in a one-liner:
#   python -c "import secrets,base64;print(base64.b64encode(secrets.token_bytes(32)).decode())"
#
# Leave empty for development — data is then stored in plaintext and
# the server boots without complaint. The first time you set this var,
# run `python -m scripts.encrypt_existing_data` to backfill existing
# rows; afterwards, every new write is automatically encrypted.
ENCRYPTION_MASTER_KEY=
# Comma-separated list of retired keys, kept only so legacy ciphertext
# can still decrypt. New writes always use ENCRYPTION_MASTER_KEY.
ENCRYPTION_OLD_KEYS=
