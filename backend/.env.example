JWT_SECRET=change-me-to-a-random-string

# LLM provider: "openai" (preferred) or "gemini" (optional)
LLM_PROVIDER=openai

# --- OpenAI (ChatGPT) — primary ---
OPENAI_API_KEY=your-openai-api-key-here

OPENAI_FALLBACK_MODELS=gpt-4o-mini,gpt-3.5-turbo
OPENAI_MAX_RETRIES=3

# --- Google Gemini (optional) ---
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-pro
GEMINI_FALLBACK_MODELS=gemini-2.5-flash,gemini-2.0-flash
GEMINI_MAX_RETRIES=3

RAG_TOP_K=3
MAX_OUTPUT_TOKENS=8192
TEMPERATURE=0.25

# --- Storage backend: "local" (default JSON files) or "firestore" ---
# Set to "firestore" to enable Google Firestore (multi-user, production-ready).
STORAGE_BACKEND=Firestore

# Required only when STORAGE_BACKEND=firestore. Pick ONE of the two
# credential mechanisms below (env-var JSON wins if both are set).
#
# Option A — RECOMMENDED for cloud (Render, Heroku, Cloud Run, Fly.io):
#   Paste the entire service-account JSON as a single env var.
#   Easiest because no file mount is needed.
# FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","..."}
# FIREBASE_CREDENTIALS_JSON={
#   "type": "service_account",
#   "project_id": "your-project-id",
#   "private_key_id": "...",
#   "private_key": "-----BEGIN PRIVATE KEY-----\n...your private key...\n-----END PRIVATE KEY-----\n",
#   "client_email": "firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com",
#   "client_id": "...",
#   "auth_uri": "https://accounts.google.com/o/oauth2/auth",
#   "token_uri": "https://oauth2.googleapis.com/token",
#   "auth_provider_x509_cert_url": "https://www.googleapis.com/oauth2/v1/certs",
#   "client_x509_cert_url": "https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk-xxxxx%40your-project-id.iam.gserviceaccount.com",
#   "universe_domain": "googleapis.com"
# }
FIREBASE_CREDENTIALS_JSON=

#
# Option B — RECOMMENDED for local dev / Docker bind-mounts:
#   Filesystem path to the downloaded service-account JSON file.
# FIREBASE_CREDENTIALS_PATH=C:\path\to\firebase-adminsdk.json
FIREBASE_CREDENTIALS_PATH=C:\Users\ro.shah\sf-qa-web\Secrets\qa-studio-agent-firebase-adminsdk-fbsvc-d2ce7019a0.json
#
# Always required when STORAGE_BACKEND=firestore (matches "project_id" in the JSON).
FIREBASE_PROJECT_ID=qa-studio-agent

# --- Google Drive integration (per-user OAuth) ---
# Create an OAuth 2.0 Client ID (type "Web application") in Google Cloud Console,
# enable the Google Drive API, and add the redirect URI below to the client config.
GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8080/api/gdrive/callback
